---
/**
 * GenussWellness (section 7) — striped section. A slider of two cards
 * (photo 930×590 + h2 + h3 + text) shifted up onto the previous section,
 * followed by the "Gastronomie" blue-grey callout (part of the same section).
 */
export interface GwColumn {
  image: string;
  imageAlt: string;
  title: string;
  eyebrow: string;
  text: string;
  list?: string[];
  text2?: string;
}
export interface GwCallout {
  title: string;
  text: string;
  buttonLabel: string;
  buttonHref: string;
}
export interface Props {
  genuss: GwColumn;
  wellness: GwColumn;
  gastro: GwCallout;
}
const { genuss, wellness, gastro } = Astro.props;
const cards = [genuss, wellness];
---

<section class="gw stripes section">
  <div class="gw__slider">
    <div class="swiper gw__swiper">
      <div class="swiper-wrapper">
        {
          cards.map((c) => (
            <div class="swiper-slide gw__card">
              <img
                class="gw__photo"
                src={c.image}
                alt={c.imageAlt}
                loading="lazy"
              />
              <div class="gw__body">
                <h2 class="gw__title">{c.title}</h2>
                <h3 class="gw__kicker">{c.eyebrow}</h3>
                <p class="gw__text">{c.text}</p>
                {c.list && (
                  <ul class="gw__list">
                    {c.list.map((li) => (
                      <li>{li}</li>
                    ))}
                  </ul>
                )}
                {c.text2 && <p class="gw__text">{c.text2}</p>}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <div class="container">
    <div class="callout s-bluegrey">
      <h2>{gastro.title}</h2>
      <p class="callout__text">{gastro.text}</p>
      <a
        class="btn callout__btn"
        href={gastro.buttonHref}
        target="_blank"
        rel="noopener"
      >
        {gastro.buttonLabel}
      </a>
    </div>
  </div>
</section>

<style>
  /* BFC so the slider's negative margin pulls the slider (not the section). */
  .gw.section {
    display: flow-root;
    padding-top: 0;
    padding-bottom: clamp(96px, 11.46vw, 220px);
  }

  /* Two cards (930px each) + 30px gap, shifted up by the photo height (590px @1920). */
  .gw__slider {
    position: relative;
    z-index: 1;
    max-width: var(--container-max); /* 1920 = 2×930 + 30 gap + 2×15 gutter */
    margin-inline: auto;
    padding-inline: 15px;
    margin-top: clamp(-590px, -30.73vw, 0px);
    margin-bottom: clamp(96px, 11.46vw, 220px);
  }

  /* height:auto (not Swiper's default 100%) lets align-items:stretch equalize slides. */
  .gw__swiper .swiper-wrapper {
    align-items: stretch;
  }
  .gw__card {
    text-align: center;
    display: flex;
    flex-direction: column;
    height: auto;
  }
  .gw__photo {
    width: 100%;
    aspect-ratio: 930 / 590;
    object-fit: cover;
    display: block;
  }
  /* flex:1 makes every card body fill the tallest slide → equal heights. */
  .gw__body {
    flex: 1 1 auto;
    background: #f0ede4;
    padding: 40px;
  }
  .gw__title {
    margin-bottom: 16px;
  }
  .gw__kicker {
    margin-bottom: 40px;
  }
  .gw__text {
    margin-bottom: var(--space-sm);
  }
  .gw__list {
    list-style: none;
    margin: var(--space-sm) 0;
    font-weight: 700;
    color: var(--color-accent);
  }

  /* "Gastronomie" blue-grey callout (same section as the slider) */
  .callout {
    max-width: 1260px;
    margin: 0 auto;
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    text-align: center;
  }
  .callout__text {
    max-width: 980px;
    margin: 50px auto;
    color: rgba(255, 255, 255, 0.95);
  }
  .callout__btn {
    background: var(--color-primary);
    border-color: var(--color-primary);
    margin-top: var(--space-sm);
  }

  @media (max-width: 768px) {
    .gw__slider {
      padding-inline: var(--space-sm);
    }
  }

  /* Tighter padding on mobile. */
  @media (max-width: 600px) {
    .callout {
      padding: var(--space-sm);
    }
    .gw__body {
      padding: 16px;
    }
  }
</style>

<script>
  import Swiper from "swiper";
  import { A11y, Keyboard } from "swiper/modules";
  import "swiper/css";

  document.querySelectorAll<HTMLElement>(".gw__slider").forEach((slider) => {
    const el = slider.querySelector<HTMLElement>(".gw__swiper");
    if (!el) return;
    new Swiper(el, {
      modules: [A11y, Keyboard],
      slidesPerView: 1,
      spaceBetween: 30,
      keyboard: { enabled: true },
      a11y: { enabled: true },
      breakpoints: {
        768: { slidesPerView: 2, spaceBetween: 30 },
      },
    });
  });
</script>
