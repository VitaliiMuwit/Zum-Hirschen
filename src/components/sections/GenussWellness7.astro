---
/**
 * GenussWellness (section 7) — striped section. A slider of two cards
 * (photo 930×590 + h2 + h3 + text) shifted up onto the previous section,
 * followed by a dashed note block (h2 + text).
 */
export interface GwColumn {
  image: string;
  imageAlt: string;
  title: string;
  eyebrow: string;
  text: string;
  list?: string[];
  text2?: string;
}
export interface GwNote {
  title: string;
  text: string;
}
export interface Props {
  genuss: GwColumn;
  wellness: GwColumn;
  note?: GwNote;
}
const { genuss, wellness, note } = Astro.props;
const cards = [genuss, wellness];
---

<section class="gw stripes section">
  <div class="gw__slider">
    <div class="swiper gw__swiper">
      <div class="swiper-wrapper">
        {
          cards.map((c) => (
            <div class="swiper-slide gw__card">
              <img class="gw__photo" src={c.image} alt={c.imageAlt} loading="lazy" />
              <h2 class="gw__title">{c.title}</h2>
              <h3 class="gw__kicker">{c.eyebrow}</h3>
              <p class="gw__text">{c.text}</p>
              {c.list && <ul class="gw__list">{c.list.map((li) => <li>{li}</li>)}</ul>}
              {c.text2 && <p class="gw__text">{c.text2}</p>}
            </div>
          ))
        }
      </div>
    </div>

    {/* Placeholder arrow icons — replace with the mockup icons. */}
    <button class="gw__nav gw__nav--prev" type="button" aria-label="Vorherige Karte">
      <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M15 4l-8 8 8 8" /></svg>
    </button>
    <button class="gw__nav gw__nav--next" type="button" aria-label="Nächste Karte">
      <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M9 4l8 8-8 8" /></svg>
    </button>
  </div>

  {
    note && (
      <div class="container section--narrow">
        <div class="gw__note">
          <h2>{note.title}</h2>
          <p>{note.text}</p>
        </div>
      </div>
    )
  }
</section>

<style>
  /* BFC so the slider's negative margin pulls the slider (not the section). */
  .gw.section {
    display: flow-root;
    padding-top: 0;
    padding-bottom: clamp(96px, 11.46vw, 220px);
  }

  /* Two cards (930px each) + 30px gap, shifted up by the photo height (590px @1920). */
  .gw__slider {
    position: relative;
    z-index: 1;
    max-width: 2010px; /* 2×930 + 30 gap + 2×60 arrow room */
    margin-inline: auto;
    padding-inline: 60px;
    margin-top: clamp(-590px, -30.73vw, 0px);
    margin-bottom: clamp(96px, 11.46vw, 220px);
  }

  .gw__card {
    text-align: center;
  }
  .gw__photo {
    width: 100%;
    aspect-ratio: 930 / 590;
    object-fit: cover;
    display: block;
    margin-bottom: 100px;
  }
  .gw__title {
    margin-bottom: 16px;
  }
  .gw__kicker {
    margin-bottom: 40px;
  }
  .gw__text {
    margin-bottom: var(--space-sm);
  }
  .gw__list {
    list-style: none;
    margin: var(--space-sm) 0;
    font-weight: 700;
    color: var(--color-accent);
  }

  .gw__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 0;
    color: var(--color-text);
    cursor: pointer;
  }
  .gw__nav--prev {
    left: 0;
  }
  .gw__nav--next {
    right: 0;
  }

  /* Dashed note block */
  .gw__note {
    border: 1px dashed var(--color-accent);
    border-radius: 30px;
    padding: 30px;
    text-align: center;
  }

  @media (max-width: 768px) {
    .gw__slider {
      padding-inline: 36px;
    }
    .gw__nav {
      width: 32px;
      height: 32px;
    }
    .gw__photo {
      margin-bottom: var(--space-lg);
    }
  }
</style>

<script>
  import Swiper from "swiper";
  import { Navigation, A11y, Keyboard } from "swiper/modules";
  import "swiper/css";

  document.querySelectorAll<HTMLElement>(".gw__slider").forEach((slider) => {
    const el = slider.querySelector<HTMLElement>(".gw__swiper");
    if (!el) return;
    new Swiper(el, {
      modules: [Navigation, A11y, Keyboard],
      slidesPerView: 1,
      spaceBetween: 30,
      keyboard: { enabled: true },
      a11y: { enabled: true },
      navigation: {
        prevEl: slider.querySelector<HTMLElement>(".gw__nav--prev"),
        nextEl: slider.querySelector<HTMLElement>(".gw__nav--next"),
      },
      breakpoints: {
        768: { slidesPerView: 2, spaceBetween: 30 },
      },
    });
  });
</script>
