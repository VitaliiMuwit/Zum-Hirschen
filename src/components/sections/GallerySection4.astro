---
/**
 * GallerySection (section 4) — "Augenblicke": photographer illustration +
 * script title + Swiper slider, on the striped (awning) background.
 * Desktop: 3 equal slides (455×379) in a row, 20px gap, infinite loop.
 * Mobile: one full-width slide.
 */
export interface GalleryImage {
  src: string;
  alt: string;
  caption?: string;
}

export interface Props {
  illustration: string;
  scriptTitle: string;
  images: GalleryImage[];
}
const { illustration, scriptTitle, images } = Astro.props;
---

<section class="augenblicke stripes section">
  <div class="container">
    <img class="deco deco--l augenblicke__deco" src={illustration} alt="" aria-hidden="true" loading="lazy" />
    <p class="script-title">{scriptTitle}</p>
  </div>

  <div class="augenblicke__slider">
    <div class="swiper augenblicke__swiper">
      <div class="swiper-wrapper">
        {
          images.map((img: GalleryImage) => (
            <div class="swiper-slide augenblicke__slide">
              <img src={img.src} alt={img.alt} loading="lazy" />
            </div>
          ))
        }
      </div>
      <div class="swiper-button-prev augenblicke__nav"></div>
      <div class="swiper-button-next augenblicke__nav"></div>
    </div>
  </div>
</section>

<style>
  /* No top padding so the photographer can overlap the previous section;
     big bottom padding (780px @1920), responsive. */
  .augenblicke.section {
    padding-top: 0;
    padding-bottom: clamp(160px, 40.62vw, 780px);
  }

  /* Photographer pulled up 40px @1920 — overlaps the section above. */
  .augenblicke__deco {
    position: relative;
    z-index: 1;
    top: clamp(-40px, -2.08vw, 0px);
    margin: 0 auto var(--space-sm);
  }

  /* Slider area sized for three 455px slides + two 20px gaps, centered. */
  .augenblicke__slider {
    max-width: calc(455px * 3 + 20px * 2 + 96px); /* + side room for arrows */
    margin-inline: auto;
    padding-inline: 48px;
    position: relative;
  }

  .augenblicke__slide img {
    width: 100%;
    aspect-ratio: 455 / 379;
    object-fit: cover;
    display: block;
  }

  .augenblicke__nav {
    --swiper-navigation-color: var(--color-text);
    --swiper-navigation-size: 30px;
  }
  .augenblicke__nav.swiper-button-prev { left: 0; }
  .augenblicke__nav.swiper-button-next { right: 0; }

  @media (max-width: 768px) {
    .augenblicke__slider { padding-inline: 24px; }
  }
</style>

<script>
  import Swiper from "swiper";
  import { Navigation, A11y, Keyboard } from "swiper/modules";
  import "swiper/css";
  import "swiper/css/navigation";

  document.querySelectorAll<HTMLElement>(".augenblicke__swiper").forEach((el) => {
    new Swiper(el, {
      modules: [Navigation, A11y, Keyboard],
      slidesPerView: 1,
      spaceBetween: 20,
      loop: true,
      keyboard: { enabled: true },
      a11y: { enabled: true },
      navigation: {
        prevEl: el.querySelector<HTMLElement>(".swiper-button-prev"),
        nextEl: el.querySelector<HTMLElement>(".swiper-button-next"),
      },
      // Desktop/tablet: three equal slides in a row.
      breakpoints: {
        768: { slidesPerView: 3, spaceBetween: 20 },
      },
    });
  });
</script>
