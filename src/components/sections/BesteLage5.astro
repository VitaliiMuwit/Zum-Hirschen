---
/**
 * BesteLage — orange section: framed photo on top + centered text.
 */
export interface Props {
  image: string;
  imageAlt: string;
  title: string;
  eyebrow: string;
  text: string;
}
const { image, imageAlt, title, eyebrow, text } = Astro.props;
---

<section class="lage s-orange">
  <div class="lage__photo">
    <img src={image} alt={imageAlt} loading="lazy" />
  </div>
  <div class="container section--narrow lage__body">
    <h2>{title}</h2>
    <p class="eyebrow eyebrow--light">{eyebrow}</p>
    <p class="lage__text">{text}</p>
  </div>
</section>

<style>
  .lage__photo { padding: var(--space-md) var(--space-md) 0; }
  .lage__photo img { width: 100%; max-height: 70vh; object-fit: cover; display: block; }
  .lage__body { text-align: center; padding-block: var(--space-xl); }
  .lage__text { color: rgba(255, 255, 255, 0.95); }
  @media (max-width: 600px) { .lage__photo { padding: var(--space-sm) var(--space-sm) 0; } }
</style>
