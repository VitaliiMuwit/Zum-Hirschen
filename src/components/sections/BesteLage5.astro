---
/**
 * BesteLage — orange section: framed photo on top + centered text.
 */
export interface Props {
  image: string;
  imageAlt: string;
  title: string;
  eyebrow: string;
  text: string;
}
const { image, imageAlt, title, eyebrow, text } = Astro.props;
---

<section class="lage s-orange">
  <div class="lage__photo">
    <img src={image} alt={imageAlt} loading="lazy" />
  </div>
  <div class="container section--narrow lage__body">
    <h2>{title}</h2>
    <h3 class="eyebrow eyebrow--light">{eyebrow}</h3>
    <p class="lage__text">{text}</p>
  </div>
</section>

<style>
  /* BFC so the photo's negative margin pulls the photo (not the section). */
  .lage.s-orange {
    display: flow-root;
    padding-bottom: clamp(96px, 11.46vw, 220px);
  }

  /* Photo (1880×1080) pulled up by half its own height → overlaps the
     section above. margin % is relative to the section width, and the photo
     height = width × 1080/1880, so -100% × 1080/1880 / 2 = -half height. */
  .lage__photo {
    padding-inline: var(--space-md);
    margin-top: calc(-100% * 1080 / 1880 / 2);
    position: relative;
    z-index: 1;
  }
  .lage__photo img {
    width: 100%;
    aspect-ratio: 1880 / 1080;
    object-fit: cover;
    display: block;
  }
  .lage__body {
    text-align: center;
    padding-top: var(--space-xl);
  }
  .lage__text {
    color: rgba(255, 255, 255, 0.95);
  }
  @media (max-width: 600px) {
    .lage__photo {
      padding-inline: var(--space-sm);
    }
  }
</style>
