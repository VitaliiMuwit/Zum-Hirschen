---
/**
 * FeatureBand (section 3) — blue-grey band with feature columns.
 * Desktop/tablet (≥900px): static 3-column row. Mobile (<900px): Swiper slider.
 */
export interface FeatureItem {
  title: string;
  text: string;
  /** Decorative illustration path. */
  icon: string;
}
export interface Props {
  items: FeatureItem[];
}
const { items } = Astro.props;
---

<section class="features section">
  <div class="features__shell">
    <div class="swiper features__swiper">
      <div class="swiper-wrapper">
        {
          items.map((f: FeatureItem) => (
            <article class="swiper-slide feature">
              <img
                class="feature__icon"
                src={f.icon}
                alt=""
                aria-hidden="true"
                loading="lazy"
              />
              <h2 class="feature__title">{f.title}</h2>
              <p class="feature__text">{f.text}</p>
            </article>
          ))
        }
      </div>
      {/* <div class="swiper-pagination features__pagination"></div> */}
    </div>
  </div>
</section>

<style>
  /* Light blue-grey background; paddings mirror HomeIntro2 (top = its bottom). */
  .features.section {
    background-color: var(--color-features);
    padding-top: clamp(126px, 15.63vw, 300px);
    padding-bottom: clamp(16px, 11.46vw, 220px);
  }

  .features__shell {
    max-width: 1560px;
    margin-inline: auto;
    padding-inline: 24px;
  }

  .feature {
    height: auto;
    text-align: center;
  }
  .feature__icon {
    height: 278px;
    width: auto;
    margin: 0 auto var(--space-sm);
  }
  /* Card title: a heading, not the uppercase kicker — taupe, non-uppercase. */
  .feature__title {
    font-size: var(--fz-40);
    line-height: 1.1;
    letter-spacing: normal;
    text-transform: none;
    margin-bottom: var(--space-sm);
    color: var(--color-accent);
  }
  .feature__text {
    color: var(--color-text); /* readable on the light background */
  }

  /* Slider chrome (mobile only). */
  .features__pagination {
    position: static;
    margin-top: var(--space-xs);
    --swiper-pagination-color: var(--color-primary);
    --swiper-pagination-bullet-inactive-color: var(--color-text);
    --swiper-pagination-bullet-inactive-opacity: 0.4;
  }
  /* No pagination on desktop (static grid). */
  @media (min-width: 900px) {
    .features__pagination {
      display: none;
    }
  }

  @media (max-width: 900px) {
    .feature__icon {
      height: 160px;
    }
    /* On mobile keep the text block to ~50% of the screen width. */
    .feature__title,
    .feature__text {
      max-width: 50vw;
      margin-inline: auto;
    }
  }
</style>

<script>
  import Swiper from "swiper";
  import { Pagination, A11y, Keyboard } from "swiper/modules";
  import "swiper/css";
  import "swiper/css/pagination";

  document.querySelectorAll<HTMLElement>(".features__swiper").forEach((el) => {
    new Swiper(el, {
      modules: [Pagination, A11y, Keyboard],
      slidesPerView: 1,
      spaceBetween: 16,
      loop: true, // infinite (auto-disabled on desktop where all 3 are shown)
      keyboard: { enabled: true },
      a11y: { enabled: true },
      pagination: {
        el: el.querySelector<HTMLElement>(".features__pagination"),
        clickable: true,
      },
      // Desktop/tablet: show all three, no sliding (static grid).
      // Gap grows toward the 1920 base (96px), scales down responsively.
      breakpoints: {
        900: { slidesPerView: 3, allowTouchMove: false, spaceBetween: 40 },
        1200: { slidesPerView: 3, allowTouchMove: false, spaceBetween: 64 },
        1560: { slidesPerView: 3, allowTouchMove: false, spaceBetween: 96 },
      },
    });
  });
</script>
