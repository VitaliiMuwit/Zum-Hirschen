---
/**
 * WohnenSection (section 6) — peach section: illustration + script title +
 * room image slider (one slide, side arrows) + caption + price accordion.
 */
export interface WohnenImage {
  src: string;
  alt: string;
  caption?: string;
}
export interface AccordionItem {
  question: string;
  answer: string;
}
export interface Props {
  illustration: string;
  scriptTitle: string;
  images: WohnenImage[];
  caption: string;
  accordion: AccordionItem[];
}
const { illustration, scriptTitle, images, caption, accordion } = Astro.props;
---

<section class="wohnen s-peach section">
  <div class="container section--narrow">
    <img class="deco deco--xl vase" src={illustration} alt="" aria-hidden="true" loading="lazy" />
    <p class="script-title">{scriptTitle}</p>
  </div>

  <div class="wohnen__slider">
    <div class="swiper wohnen__swiper">
      <div class="swiper-wrapper">
        {
          images.map((img: WohnenImage) => (
            <div class="swiper-slide wohnen__slide">
              <img src={img.src} alt={img.alt} loading="lazy" />
            </div>
          ))
        }
      </div>
    </div>

    {/* Placeholder arrow icons — replace the inline SVGs with the mockup icons. */}
    <button class="wohnen__nav wohnen__nav--prev" type="button" aria-label="Vorheriges Bild">
      <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M15 4l-8 8 8 8" />
      </svg>
    </button>
    <button class="wohnen__nav wohnen__nav--next" type="button" aria-label="Nächstes Bild">
      <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M9 4l8 8-8 8" />
      </svg>
    </button>
  </div>

  <div class="container section--narrow">
    <p class="wohnen__caption">{caption}</p>

    <div class="accordion">
      {
        accordion.map((item) => (
          <details class="accordion__item">
            <summary class="accordion__q">{item.question}</summary>
            <p class="accordion__a">{item.answer}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .wohnen.section {
    padding-block: clamp(96px, 11.46vw, 220px);
  }
  .wohnen .container {
    text-align: center;
  }

  /* Image slider — one slide (1260×800 @1920), arrows on the sides. */
  .wohnen__slider {
    position: relative;
    max-width: 1380px; /* 1260 image + arrow room */
    margin: var(--space-md) auto var(--space-lg);
    padding-inline: 60px;
  }
  .wohnen__slide img {
    width: 100%;
    aspect-ratio: 1260 / 800;
    object-fit: cover;
    display: block;
  }
  .wohnen__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 0;
    color: var(--color-text);
    cursor: pointer;
  }
  .wohnen__nav--prev {
    left: 0;
  }
  .wohnen__nav--next {
    right: 0;
  }

  .wohnen__caption {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: var(--fs-small);
    color: var(--color-text);
    max-width: 760px;
    margin: 0 auto var(--space-lg);
  }

  /* Accordion */
  .accordion {
    max-width: 820px;
    margin: 0 auto;
  }
  .accordion__item {
    border-bottom: 1px solid var(--color-border);
  }
  .accordion__q {
    cursor: pointer;
    list-style: none;
    padding: var(--space-sm) 0;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 12px;
    font-weight: 600;
    color: var(--color-text);
    text-align: center;
  }
  .accordion__q::-webkit-details-marker {
    display: none;
  }
  /* Chevron drawn with borders (no glyph) — points down, flips up when open. */
  .accordion__q::after {
    content: "";
    width: 9px;
    height: 9px;
    border-right: 2px solid var(--color-primary);
    border-bottom: 2px solid var(--color-primary);
    transform: rotate(45deg);
    transition: transform 0.2s ease;
  }
  .accordion__item[open] .accordion__q::after {
    transform: rotate(-135deg);
  }
  .accordion__a {
    text-align: center;
    color: var(--color-text);
    padding-bottom: var(--space-sm);
  }

  @media (max-width: 768px) {
    .wohnen__slider {
      padding-inline: 36px;
    }
    .wohnen__nav {
      width: 32px;
      height: 32px;
    }
  }
</style>

<script>
  import Swiper from "swiper";
  import { Navigation, A11y, Keyboard } from "swiper/modules";
  import "swiper/css";

  document.querySelectorAll<HTMLElement>(".wohnen__slider").forEach((slider) => {
    const el = slider.querySelector<HTMLElement>(".wohnen__swiper");
    if (!el) return;
    new Swiper(el, {
      modules: [Navigation, A11y, Keyboard],
      slidesPerView: 1,
      loop: true,
      keyboard: { enabled: true },
      a11y: { enabled: true },
      navigation: {
        prevEl: slider.querySelector<HTMLElement>(".wohnen__nav--prev"),
        nextEl: slider.querySelector<HTMLElement>(".wohnen__nav--next"),
      },
    });
  });
</script>
