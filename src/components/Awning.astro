---
/**
 * Awning ("Markise") — decorative scalloped strip in the Zum Hirschen style.
 * Alternating cream (var(--color-cream)) and yellow (var(--color-awning)) teeth.
 * Teeth are ~67×99px on a 1920px screen (30 teeth, flex-sized) and scale down responsively.
 */
const TEETH = 30;
---

<div class="awning" aria-hidden="true">
  {Array.from({ length: TEETH }).map(() => <span></span>)}
</div>

<style>
  .awning {
    display: flex;
    height: 33px;
    overflow: hidden;
    pointer-events: none;
  }

  .awning span {
    flex: 1 0 0;
    height: 33px;
    border-radius: 0 0 50% 50%;
  }

  .awning span:nth-child(odd) {
    background: var(--color-awning); /* yellow */
  }
  .awning span:nth-child(even) {
    background: var(--color-cream); /* cream */
  }

  @media (max-width: 900px) {
    .awning,
    .awning span {
      height: 30px;
    }
  }

  @media (max-width: 480px) {
    .awning,
    .awning span {
      height: 26px;
    }
  }
</style>
