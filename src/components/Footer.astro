---
/**
 * Footer — two parts:
 *  1) contact section (logo, address, phone, email, social, Maps, languages)
 *  2) bottom section (Impressum / Datenschutz on the left, partners in the center, Muwit on the right)
 *
 * Labels come through props (language-agnostic component).
 * All contact / address / social / Muwit data comes from src/config/.
 */
import { site } from "../config/site";
import { contact } from "../config/contact";
import { social } from "../config/social";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import type { Locale } from "../i18n";

export interface FooterLabels {
  mapsLabel: string;
  impressum: string;
  datenschutz: string;
  socialAria: string;
  legalAria: string;
}

export interface Props {
  locale: Locale;
  labels: FooterLabels;
  /** Localized URLs of the legal pages. */
  impressumHref: string;
  datenschutzHref: string;
}

const { locale, labels, impressumHref, datenschutzHref } = Astro.props;

const { address } = contact;

// Only show social links that have a URL configured.
const socialLinks = social.filter((s) => s.href);
---

<footer class="footer">
  <div class="footer__top container">
    <div class="footer__brand">
      <img class="footer__logo" src={site.logo} alt={site.name} width="180" height="100" />
      <span class="footer__name">{site.company.name}</span>
    </div>

    <address class="footer__contact">
      <p>{address.street}<br />{address.zip} {address.city}, {address.country}</p>
      <p>
        <a href={contact.phoneHref}>{contact.phone}</a><br />
        <a href={contact.emailHref}>{contact.email}</a>
      </p>
      <a href={contact.googleMapsUrl} class="footer__maps" target="_blank" rel="noopener">
        {labels.mapsLabel}
      </a>
    </address>

    <div class="footer__meta">
      <ul class="footer__social" aria-label={labels.socialAria}>
        {
          socialLinks.map((s) => (
            <li>
              <a href={s.href} target="_blank" rel="noopener">
                {s.label}
              </a>
            </li>
          ))
        }
      </ul>
      <LanguageSwitcher current={locale} variant="full" class="footer__langs" />
    </div>
  </div>

  <div class="footer__bottom">
    <div class="footer__bottom-inner container">
      <nav class="footer__legal" aria-label={labels.legalAria}>
        <a href={impressumHref}>{labels.impressum}</a>
        <a href={datenschutzHref}>{labels.datenschutz}</a>
      </nav>

      <div class="footer__partners" aria-label="Partner">
        <!-- Partner logos go here (configurable per client). -->
      </div>

      <a href={site.muwit.url} class="footer__muwit" target="_blank" rel="noopener">
        {site.muwit.name}
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-text);
    color: #f3ece2;
  }

  .footer__top {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-lg);
    padding-block: var(--space-xl);
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }

  /* Wide wordmark logo — keep aspect ratio. */
  .footer__logo {
    width: auto;
    height: 48px;
    max-width: 220px;
  }

  .footer__name {
    font-family: var(--font-heading);
    font-size: 21px;
  }

  .footer__contact {
    font-style: normal;
    line-height: 1.8;
  }

  .footer__contact a:hover {
    color: var(--color-accent);
  }

  .footer__maps {
    display: inline-block;
    margin-top: var(--space-xs);
    color: var(--color-accent);
    text-decoration: underline;
  }

  .footer__social {
    display: flex;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .footer__social a:hover,
  .footer__langs :global(.lang-switcher__item:hover) {
    color: var(--color-accent);
  }

  .footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .footer__bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding-block: var(--space-md);
    flex-wrap: wrap;
  }

  .footer__legal {
    display: flex;
    gap: var(--space-md);
    font-size: var(--fs-small);
  }

  .footer__legal a:hover {
    color: var(--color-accent);
  }

  .footer__muwit {
    font-family: var(--font-heading);
    font-size: 18px;
    letter-spacing: 0.1em;
  }
</style>
