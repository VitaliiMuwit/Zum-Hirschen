---
/**
 * Footer — light (cream) footer matching the Figma:
 *  1) centered column: logo · address · phone/email · social icons · Maps button
 *  2) legal bar: Impressum / Privacy / Cookies (left) + language switcher (right)
 *  3) full-bleed white bar with centered partner logos
 *
 * Labels come through props (language-agnostic component).
 * Contact / address / social / partner data comes from src/config/.
 */
import { site } from "../config/site";
import { contact } from "../config/contact";
import { social } from "../config/social";
import { partners } from "../config/partners";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { withBase, type Locale } from "../i18n";

export interface FooterLabels {
  mapsLabel: string;
  impressum: string;
  privacy: string;
  cookies: string;
  socialAria: string;
  legalAria: string;
}

export interface Props {
  locale: Locale;
  labels: FooterLabels;
  /** Localized URLs of the legal pages. */
  impressumHref: string;
  datenschutzHref: string;
}

const { locale, labels, impressumHref, datenschutzHref } = Astro.props;

const { address } = contact;

// Only show social links that have a URL configured.
const socialLinks = social.filter((s) => s.href);
---

<footer class="footer">
  <div class="footer__main container">
    <img
      class="footer__logo"
      src={withBase(site.logoFooter)}
      alt={site.name}
      width="320"
      height="180"
    />

    <address class="footer__contact">
      <p class="footer__holder">{address.holder}</p>
      <p>
        {address.street}<br />
        I-{address.zip}
        {address.city}<br />
        {address.region}
      </p>
      <p class="footer__phone">
        <span>T. {contact.phone}</span><br />
        <a class="footer__email" href={contact.emailHref}>{contact.email}</a>
      </p>
    </address>

    {
      socialLinks.length > 0 && (
        <ul class="footer__social" aria-label={labels.socialAria}>
          {socialLinks.map((s) => (
            <li>
              <a
                href={s.href}
                target="_blank"
                rel="noopener"
                aria-label={s.label}
              >
                {s.label.toLowerCase().includes("insta") ? (
                  <svg
                    width="22"
                    height="22"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.6"
                    aria-hidden="true"
                  >
                    <rect x="3" y="3" width="18" height="18" rx="5" />
                    <circle cx="12" cy="12" r="4" />
                    <circle
                      cx="17.5"
                      cy="6.5"
                      r="1"
                      fill="currentColor"
                      stroke="none"
                    />
                  </svg>
                ) : (
                  <svg
                    width="22"
                    height="22"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M14 9h3V5.5h-3c-2.2 0-4 1.8-4 4V12H7.5v3.5H10V22h3.5v-6.5H16L16.5 12h-3V9.5c0-.3.2-.5.5-.5z" />
                  </svg>
                )}
              </a>
            </li>
          ))}
        </ul>
      )
    }

    <div class="footer__legalbar">
      <nav class="footer__legal" aria-label={labels.legalAria}>
        <a href={impressumHref}>{labels.impressum}</a>
        <a href={datenschutzHref}>{labels.privacy}</a>
        <a href={datenschutzHref}>{labels.cookies}</a>
      </nav>
      <a
        class="btn btn--bluegrey footer__maps"
        href={contact.googleMapsUrl}
        target="_blank"
        rel="noopener"
      >
        {labels.mapsLabel}
      </a>
      <div class="footer__langs">
        <LanguageSwitcher current={locale} variant="full" />
      </div>
    </div>
  </div>

  {
    partners.length > 0 && (
      <div class="footer__partners-bar">
        <ul class="footer__partners container" aria-label="Partner">
          {partners.map((p) => {
            const logo = <img src={withBase(p.logo)} alt={p.alt} loading="lazy" />;
            return (
              <li>
                {p.href ? (
                  <a href={p.href} target="_blank" rel="noopener">
                    {logo}
                  </a>
                ) : (
                  logo
                )}
              </li>
            );
          })}
        </ul>
      </div>
    )
  }
</footer>

<style>
  .footer {
    background-color: var(--color-bg);
    color: var(--color-accent);
  }

  /* Centered column */
  .footer__main {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-block: clamp(48px, 5vw, 96px);
  }

  .footer__logo {
    width: auto;
    height: clamp(90px, 9vw, 164px);
    margin-bottom: var(--space-xl);
  }

  .footer__contact {
    font-style: normal;
    line-height: 1.8;
    font-size: var(--fz-20);
  }
  .footer__contact p {
    color: var(--color-accent);
  }
  /* Gap only before the phone/email block — holder sits tight on the address. */
  .footer__phone {
    margin-top: 32px;
  }
  .footer__holder {
    font-weight: 700;
  }
  .footer__email {
    text-decoration: underline;
  }
  .footer__contact a:hover {
    color: var(--color-text);
  }

  .footer__social {
    display: flex;
    justify-content: center;
    gap: var(--space-md);
    margin: var(--space-lg) 0;
  }
  .footer__social a {
    display: inline-flex;
    color: var(--color-accent);
  }
  .footer__social a:hover {
    color: var(--color-text);
  }

  .footer__maps {
    white-space: nowrap;
    flex: 0 0 auto; /* keep its own width; the side columns center it */
  }

  /* Bottom row: legal links · Maps button · languages.
     Equal flex:1 side columns keep the button perfectly centered
     regardless of the legal/language text length. */
  .footer__legalbar {
    width: 100%;
    display: flex;
    align-items: flex-end;
    gap: var(--space-md);
    flex-wrap: wrap;
  }
  .footer__legal {
    flex: 1;
    display: flex;
    gap: var(--space-lg);
    margin-left: 40px; /* push the legal links to the left */
  }
  .footer__langs {
    flex: 1;
    display: flex;
    justify-content: center;
  }
  .footer__legal a {
    font-size: var(--fs-small);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .footer__legal a:hover,
  .footer__langs :global(.lang-switcher__item:hover) {
    color: var(--color-text);
  }

  /* White partner bar (full-bleed) */
  .footer__partners-bar {
    background-color: #ffffff;
  }
  .footer__partners {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(40px, 6vw, 120px);
    flex-wrap: wrap;
    padding-block: var(--space-xs);
  }
  .footer__partners img {
    height: 56px;
    width: auto;
    object-fit: contain;
  }

  @media (max-width: 600px) {
    .footer__legalbar {
      flex-direction: column;
      align-items: center;
      gap: var(--space-sm);
    }
    .footer__legal {
      gap: var(--space-md);
    }
    .footer__legal,
    .footer__langs {
      justify-content: center;
    }
  }
</style>
