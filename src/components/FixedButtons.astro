---
/**
 * FixedButtons — sticky CTA "pill" (Zum Hirschen style).
 *
 * Fixed at the top-right and stays visible while scrolling. Two stacked
 * actions (orange "booking" + blue-grey "inquiry") with a round bell badge.
 * Buttons come through props (already localized; `primary` = booking/orange).
 * On mobile it becomes a compact bottom bar.
 */
export interface FixedButton {
  label: string;
  href: string;
  primary?: boolean;
}

export interface Props {
  buttons: FixedButton[];
  ariaLabel: string;
}

const { buttons, ariaLabel } = Astro.props;
---

<aside class="cta-pill" aria-label={ariaLabel}>
  <div class="cta-pill__buttons">
    {
      buttons.map((b) => (
        <a href={b.href} class={`cta-pill__btn${b.primary ? " cta-pill__btn--booking" : " cta-pill__btn--inquiry"}`}>
          {b.label}
        </a>
      ))
    }
  </div>
  <span class="cta-pill__bell" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9" />
      <path d="M13.7 21a2 2 0 0 1-3.4 0" />
    </svg>
  </span>
</aside>

<style>
  .cta-pill {
    position: fixed;
    top: 150px; /* below the (non-fixed) header on the hero */
    right: 24px;
    z-index: var(--z-fixed);
    display: flex;
    align-items: center;
  }

  .cta-pill__buttons {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: var(--shadow);
  }

  .cta-pill__btn {
    padding: 0.7rem 3.25rem 0.7rem 1.25rem; /* extra right padding under the bell */
    font-size: 1rem;
    font-weight: 600;
    color: #fff;
    text-align: left;
  }

  .cta-pill__btn--booking {
    background-color: var(--color-primary); /* #F78650 */
  }
  .cta-pill__btn--inquiry {
    background-color: var(--color-secondary); /* #96ABB0 */
  }

  /* Round bell badge overlapping the right edge — kept above the buttons. */
  .cta-pill__bell {
    position: relative;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    margin-left: -32px;
    border-radius: 50%;
    background-color: #f8d167; /* gold */
    box-shadow: var(--shadow);
  }

  /* Mobile: compact full-width bottom bar */
  @media (max-width: 768px) {
    .cta-pill {
      top: auto;
      bottom: 0;
      right: 0;
      left: 0;
    }
    .cta-pill__buttons {
      flex: 1;
      flex-direction: row;
      border-radius: 0;
    }
    .cta-pill__btn {
      flex: 1;
      text-align: center;
      padding: 0.9rem 0.5rem;
      font-size: 0.9rem;
    }
    .cta-pill__bell {
      display: none;
    }
  }
</style>

<!-- Reserve space at the bottom on mobile so the fixed bar never covers content. -->
<style is:global>
  @media (max-width: 768px) {
    body {
      padding-bottom: 3.5rem;
    }
  }
</style>
