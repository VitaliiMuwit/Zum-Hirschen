---
/**
 * Header (Zum Hirschen) — awning strip + centered brand logo + "Menü" button.
 *
 * Brand identity migrated from the old site: scalloped awning, inline deer mark,
 * "★★★ hotel · restaurant" and the "Zum Hirschen" script wordmark.
 * Transparent over the hero; gets a solid cream background on scroll.
 *
 * Menu opens as a fullscreen overlay (MenuOverlay). Texts/menu via props.
 */
import { site } from "../config/site";
import Awning from "./Awning.astro";
import MenuOverlay, { type MenuLink } from "./MenuOverlay.astro";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { localizePath, type Locale } from "../i18n";

export interface HeaderUi {
  menuButton: string;
  menuClose: string;
  menuAria: string;
  navAria: string;
  homeAria: string;
}

export interface Props {
  locale: Locale;
  menu: MenuLink[];
  ui: HeaderUi;
}

const { locale, menu, ui } = Astro.props;
const homeHref = localizePath(locale, "/");
const homeLabel = menu[0]?.label ?? "Home";
---

<header id="site-header" class="header">
  <Awning />

  <div class="header__bar container">
    <a href={homeHref} class="header__breadcrumb">{homeLabel}</a>

    <a href={homeHref} class="brand" aria-label={`${site.name} – ${ui.homeAria}`}>
      <span class="brand__deer" aria-hidden="true">
        <svg viewBox="0 0 64 64" width="44" height="44" fill="currentColor">
          <path d="M32 24c-3 0-5 2-5 5v3l-4 8c-1 2 1 4 3 3l6-3 6 3c2 1 4-1 3-3l-4-8v-3c0-3-2-5-5-5z" />
          <path d="M27 24c-2-3-3-7-7-9-2-1-4-3-4-6 3 1 5 2 6 4 1-3 0-6-2-8 4 1 6 4 6 8 1-2 1-5 0-7 3 2 4 6 3 10 1 2 2 5 1 8z" />
          <path d="M37 24c2-3 3-7 7-9 2-1 4-3 4-6-3 1-5 2-6 4-1-3 0-6 2-8-4 1-6 4-6 8-1-2-1-5 0-7-3 2-4 6-3 10-1 2-2 5-1 8z" />
        </svg>
      </span>
      <span class="brand__sub">★★★ hotel · restaurant</span>
      <span class="brand__name">Zum Hirschen</span>
    </a>

    <div class="header__actions">
      <LanguageSwitcher current={locale} variant="compact" class="header__langs" />
      <button
        type="button"
        class="header__menu-btn"
        data-menu-open
        aria-haspopup="dialog"
        aria-controls="menu-overlay"
      >
        <span class="header__menu-label">{ui.menuButton}</span>
        <span class="header__menu-icon" aria-hidden="true"></span>
      </button>
    </div>
  </div>
</header>

<MenuOverlay
  locale={locale}
  menu={menu}
  closeLabel={ui.menuClose}
  ariaLabel={ui.menuAria}
  navAriaLabel={ui.navAria}
/>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-header);
    color: #fff; /* white over the hero photo */
    transition: background-color var(--transition), box-shadow var(--transition), color var(--transition);
  }

  /* Solid cream background once scrolled past the hero top. */
  .header.is-scrolled {
    background-color: var(--color-bg);
    box-shadow: var(--shadow);
    color: var(--color-text);
  }
  .header.is-scrolled .awning {
    display: none;
  }

  .header__bar {
    position: relative;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-block: 1.25rem;
    min-height: 92px;
  }

  .header__breadcrumb {
    position: absolute;
    left: var(--container-padding);
    top: 1.25rem;
    font-size: 0.95rem;
    font-weight: 300;
    opacity: 0.85;
  }

  /* Centered brand (deer + sub + script name) */
  .brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.35);
    color: inherit;
  }
  .header.is-scrolled .brand {
    text-shadow: none;
  }

  .brand__deer {
    line-height: 1;
  }
  .brand__sub {
    letter-spacing: 0.28em;
    font-size: 0.62rem;
    text-transform: lowercase;
    opacity: 0.95;
    margin: 4px 0 2px;
  }
  .brand__name {
    font-family: var(--font-heading); /* Dancing Script */
    font-size: 2.4rem;
    font-weight: 700;
    line-height: 1;
  }

  .header__actions {
    position: absolute;
    right: var(--container-padding);
    top: 1.25rem;
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .header__langs :global(.lang-switcher__item.is-active) {
    color: var(--color-secondary);
  }
  .header.is-scrolled .header__langs :global(.lang-switcher__item.is-active) {
    color: var(--color-primary);
  }

  .header__menu-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: none;
    border: 0;
    color: inherit;
    font-family: var(--font-body);
    font-size: 1.1rem;
    cursor: pointer;
    padding: 0.25rem;
  }

  /* Two-bar hamburger like the old site. */
  .header__menu-icon {
    position: relative;
    width: 30px;
    height: 14px;
    display: inline-block;
  }
  .header__menu-icon::before,
  .header__menu-icon::after {
    content: "";
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: currentColor;
  }
  .header__menu-icon::before {
    top: 3px;
  }
  .header__menu-icon::after {
    bottom: 3px;
  }

  @media (max-width: 600px) {
    .header__langs,
    .header__breadcrumb {
      display: none;
    }
    .brand__name {
      font-size: 1.9rem;
    }
    .header__menu-label {
      display: none;
    }
  }
</style>

<script>
  // Solid background once the user scrolls past the hero top.
  const header = document.getElementById("site-header");
  const onScroll = () => {
    if (!header) return;
    header.classList.toggle("is-scrolled", window.scrollY > 80);
  };
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });
</script>
