---
/**
 * Header (Zum Hirschen) — awning strip + centered brand logo + "Menü" button.
 *
 * Brand identity migrated from the old site: scalloped awning, inline deer mark,
 * "★★★ hotel · restaurant" and the "Zum Hirschen" script wordmark.
 * Transparent over the hero; gets a solid cream background on scroll.
 *
 * Menu opens as a fullscreen overlay (MenuOverlay). Texts/menu via props.
 */
import { site } from "../config/site";
import Awning from "./Awning.astro";
import MenuOverlay, { type MenuLink } from "./MenuOverlay.astro";
import { withBase, localizePath, type Locale } from "../i18n";

export interface HeaderUi {
  menuButton: string;
  menuClose: string;
  menuAria: string;
  navAria: string;
  homeAria: string;
}

export interface Props {
  locale: Locale;
  menu: MenuLink[];
  ui: HeaderUi;
}

const { locale, menu, ui } = Astro.props;
const homeHref = localizePath(locale, "/");
---

<header id="site-header" class="header">
  <Awning />

  <div class="header__bar">
    <a href={homeHref} class="brand" aria-label={`${site.name} – ${ui.homeAria}`}>
      <img class="brand__logo" src={withBase(site.logo)} alt={site.name} width="296" height="164" />
    </a>

    <button
      type="button"
      class="header__menu-btn"
      data-menu-open
      aria-haspopup="dialog"
      aria-controls="menu-overlay"
    >
      <span class="header__menu-label">{ui.menuButton}</span>
      <svg class="header__menu-icon" width="74" height="30" viewBox="0 0 78 34" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
        <path d="M2 2H76" stroke="currentColor" stroke-width="4" stroke-linecap="round" />
        <path d="M2 17H76" stroke="currentColor" stroke-width="4" stroke-linecap="round" />
        <path d="M2 32H76" stroke="currentColor" stroke-width="4" stroke-linecap="round" />
      </svg>
    </button>
  </div>
</header>

<MenuOverlay
  locale={locale}
  menu={menu}
  closeLabel={ui.menuClose}
  ariaLabel={ui.menuAria}
  navAriaLabel={ui.navAria}
/>

<style>
  /* Overlays the top of the hero photo and scrolls away with the page (not fixed). */
  .header {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-header);
    color: #fff; /* white over the hero photo */
  }

  /* Full-width bar: only 20px side padding, logo centered, menu pinned right. */
  .header__bar {
    position: relative;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 20px 20px;
    min-height: 92px;
  }

  /* Centered brand logo */
  .brand {
    display: flex;
    align-items: center;
    justify-content: center;
    color: inherit;
  }

  /* Logo: 296×164 max on a 1920px screen, scales down responsively. */
  .brand__logo {
    width: clamp(160px, 15.4vw, 296px);
    height: auto;
    display: block;
    /* soft shadow so the light wordmark stays legible over the hero photo */
    filter: drop-shadow(0 2px 10px rgba(0, 0, 0, 0.35));
  }

  .header__menu-btn {
    position: absolute;
    right: 20px;
    top: 24px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: none;
    border: 0;
    color: inherit;
    font-family: var(--font-body);
    font-size: 18px;
    cursor: pointer;
    padding: 4px;
  }

  /* Menu icon SVG — 74×30 on a 1920px base, scales down responsively. */
  .header__menu-icon {
    display: block;
    width: clamp(40px, 3.85vw, 74px);
    height: auto;
    color: var(--color-cream); /* stroke uses currentColor */
  }

  @media (max-width: 600px) {
    .header__menu-label {
      display: none;
    }
  }
</style>
