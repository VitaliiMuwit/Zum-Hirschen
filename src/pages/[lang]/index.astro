---
/**
 * Home page (Hotel zum Hirschen) — composed from section components.
 * Section components are numbered by their order on the page (hero = 1):
 *   1 hero (inline) · 2 Intro · 3 Features · 4 Gallery · 5 BesteLage ·
 *   6 Wohnen · 7 Genuss&Wellness (incl. Gastronomie callout) · 8 Erleben · 9 Warum.
 * Reorder/remove sections by editing this file only; data from content/{lang}/pages/home.ts.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import HomeIntro2 from "../../components/sections/HomeIntro2.astro";
import FeatureBand3 from "../../components/sections/FeatureBand3.astro";
import GallerySection4 from "../../components/sections/GallerySection4.astro";
import BesteLage5 from "../../components/sections/BesteLage5.astro";
import WohnenSection6 from "../../components/sections/WohnenSection6.astro";
import GenussWellness7 from "../../components/sections/GenussWellness7.astro";
import ErlebenSection8 from "../../components/sections/ErlebenSection8.astro";
import WarumList9 from "../../components/sections/WarumList9.astro";
import { getSeo } from "../../config/seo";
import { locales, getTranslations, withBase, type Locale } from "../../i18n";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const { home } = getTranslations(lang);
const heroBg = withBase("/images/head.webp");
---

<BaseLayout locale={lang} seo={getSeo("home", lang)}>
  <!-- 1) Clean hero photo (logo + menu overlaid by the header) -->
  <section class="hero-photo" aria-label={home.hero.slides[0].alt}></section>

  <HomeIntro2
    title={home.about.title}
    eyebrow={home.about.eyebrow}
    paragraphs={home.about.paragraphs}
    hinweis={home.about.hinweis}
  />

  <FeatureBand3 items={home.features} />

  <GallerySection4
    illustration={home.gallery.illustration}
    scriptTitle={home.gallery.scriptTitle}
    images={home.gallery.images}
  />

  <BesteLage5
    image={home.bestLage.image}
    imageAlt={home.bestLage.imageAlt}
    title={home.bestLage.title}
    eyebrow={home.bestLage.eyebrow}
    text={home.bestLage.text}
  />

  <WohnenSection6
    illustration={home.wohnen.illustration}
    scriptTitle={home.wohnen.scriptTitle}
    images={home.wohnen.images}
    caption={home.wohnen.caption}
    accordion={home.wohnen.accordion}
  />

  <GenussWellness7
    genuss={home.genuss}
    wellness={home.wellness}
    gastro={home.gastronomie}
  />

  <ErlebenSection8
    illustration={home.erleben.illustration}
    scriptTitle={home.erleben.scriptTitle}
    intro={home.erleben.intro}
    cards={home.erleben.cards}
    buttonLabel={home.erleben.buttonLabel}
    buttonHref={home.erleben.buttonHref}
  />

  <WarumList9 title={home.warum.title} items={home.warum.items} />
</BaseLayout>

<style define:vars={{ heroBg: `url(${heroBg})` }}>
  /* Clean hero: full-bleed photo; the header (logo + menu) overlays its top.
     Height: 100vh desktop, 60vh tablet, 40vh mobile. */
  .hero-photo {
    height: 100vh;
    background: var(--heroBg) center / cover no-repeat;
  }
  @media (max-width: 900px) {
    .hero-photo { height: 60vh; }
  }
  @media (max-width: 600px) {
    .hero-photo { height: 40vh; }
  }
</style>
