---
/**
 * Datenschutz & Cookies — legal page, one per language.
 * Content comes from content/{lang}/legal.ts.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSeo } from "../../config/seo";
import { locales, getTranslations, type Locale } from "../../i18n";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const { legal } = getTranslations(lang);
const d = legal.datenschutz;
---

<BaseLayout locale={lang} seo={getSeo("datenschutz", lang)} showFixedButtons={false}>
  <article class="section container section--narrow legal">
    <h1>{d.title}</h1>

    {
      d.sections.map((s) => (
        <>
          <h2>{s.heading}</h2>
          <p>{s.text}</p>
        </>
      ))
    }

    <p><em>{d.note}</em></p>
  </article>
</BaseLayout>

<style is:global>
  .legal h1 {
    margin-bottom: var(--space-md);
  }
  .legal h2 {
    margin-top: var(--space-md);
    margin-bottom: var(--space-xs);
    font-size: var(--fs-h3);
  }
  .legal a {
    color: var(--color-primary);
    text-decoration: underline;
  }
</style>
