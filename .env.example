# Resend — email sending for the Anfrage form.
# Copy this file to `.env` and fill in the real values.
# Get the key at https://resend.com → API Keys.

# Resend API key (secret, do not commit).
RESEND_API_KEY=your_resend_api_key_here

# Client email that receives the form submissions.
CONTACT_FORM_TO_EMAIL=info@zumhirschen.it

# Sender email. The domain must be verified in Resend.
CONTACT_FORM_FROM_EMAIL=info@zumhirschen.it
